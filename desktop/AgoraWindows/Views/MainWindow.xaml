<Window x:Class="AgoraWindows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agora" Width="1000" Height="650"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Closing="Window_Closing">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- User header -->
                <Border DockPanel.Dock="Top" Padding="16,12"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock x:Name="UserDisplayName" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock x:Name="UserStatus" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <!-- Channel list header -->
                <Border DockPanel.Dock="Top" Padding="16,10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock x:Name="ChatsHeader" Text="Chats" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </Border>

                <!-- Channel list -->
                <ListBox x:Name="ChannelList" BorderThickness="0"
                         SelectionChanged="ChannelList_SelectionChanged"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,6">
                                <DockPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding UnreadCount}" FontSize="11"
                                               Foreground="White" Background="{StaticResource PrimaryBrush}"
                                               Padding="4,1" HorizontalAlignment="Right"
                                               Visibility="{Binding UnreadCount, Converter={x:Static local:Converters.IntToVisibility}}" />
                                </DockPanel>
                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                    <Run Text="{Binding MemberCount}" /><Run Text=" members" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Main content area -->
        <Grid Grid.Column="1">
            <!-- Empty state -->
            <StackPanel x:Name="EmptyState" VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock x:Name="EmptyStateTitle" Text="Welcome to Agora" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="EmptyStateSubtitle" Text="Select a chat" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>

            <!-- Chat view -->
            <Grid x:Name="ChatView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Chat header -->
                <Border Grid.Row="0" Padding="16,12" Background="White"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock x:Name="ChatTitle" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </Border>

                <!-- Messages -->
                <ScrollViewer Grid.Row="1" x:Name="MessageScroll"
                              VerticalScrollBarVisibility="Auto" Padding="16">
                    <ItemsControl x:Name="MessageList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,4" Padding="8,6" Background="White"
                                        CornerRadius="6">
                                    <StackPanel>
                                        <!-- Reply quote -->
                                        <Border Margin="0,0,0,4" Padding="6,4"
                                                BorderBrush="{StaticResource PrimaryBrush}"
                                                BorderThickness="3,0,0,0" Background="#F0F0F0"
                                                CornerRadius="2"
                                                Visibility="{Binding ReplyToSender, Converter={x:Static local:Converters.StringToVisibility}}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding ReplyToSender}" FontSize="11"
                                                           FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" />
                                                <TextBlock Text="{Binding ReplyToContent}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis" MaxHeight="20" />
                                            </StackPanel>
                                        </Border>

                                        <!-- Header: sender + time -->
                                        <DockPanel>
                                            <TextBlock FontSize="12" Foreground="{StaticResource PrimaryBrush}">
                                                <Run Text="{Binding SenderName}" FontWeight="SemiBold" />
                                                <Run Text="{Binding EditedIndicator}" FontStyle="Italic"
                                                     Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding CreatedAt}" FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center" />
                                        </DockPanel>

                                        <!-- Content -->
                                        <TextBlock Text="{Binding Content}" FontSize="13"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />

                                        <!-- Reactions -->
                                        <TextBlock Text="{Binding DisplayReactions}" FontSize="12"
                                                   Margin="0,4,0,0"
                                                   Visibility="{Binding DisplayReactions, Converter={x:Static local:Converters.StringToVisibility}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Typing indicator -->
                <Border Grid.Row="2" x:Name="TypingBar" Padding="12,4" Background="White"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TypingText" FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Border>

                <!-- Message input -->
                <Border Grid.Row="3" Padding="12" Background="White"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <Button x:Name="SendButton" DockPanel.Dock="Right" Content="Send"
                                Style="{StaticResource PrimaryButton}"
                                Click="SendButton_Click" Margin="8,0,0,0"
                                Height="34" Padding="16,0" />
                        <TextBox x:Name="MessageInput" Padding="8,6" FontSize="13"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 KeyDown="MessageInput_KeyDown"
                                 AcceptsReturn="False" />
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Toast notification popup -->
        <Border x:Name="ToastBorder" Grid.Column="1"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="16,16" Padding="12,10" CornerRadius="8"
                Background="#323232" Visibility="Collapsed"
                MaxWidth="350">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Opacity="0.3" ShadowDepth="4" />
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="ToastTitle" FontSize="12" FontWeight="SemiBold"
                           Foreground="White" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ToastBody" FontSize="11" Foreground="#CCCCCC"
                           TextWrapping="Wrap" MaxHeight="40"
                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
