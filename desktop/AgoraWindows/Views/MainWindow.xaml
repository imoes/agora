<Window x:Class="AgoraWindows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AgoraWindows.Views"
        xmlns:helpers="clr-namespace:AgoraWindows.Helpers"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Agora" Width="1100" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Closing="Window_Closing"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Dark icon sidebar -->
            <ColumnDefinition Width="52" />
            <!-- Channel/list sidebar -->
            <ColumnDefinition Width="260" />
            <!-- Main content area -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- === COLUMN 0: Dark icon sidebar === -->
        <Border Grid.Column="0" Background="{StaticResource SidebarDarkBrush}">
            <DockPanel>
                <!-- Bottom: User avatar -->
                <Button DockPanel.Dock="Bottom" Click="SettingsButton_Click"
                        Width="36" Height="36" Margin="0,0,0,12" Cursor="Hand"
                        ToolTip="Settings">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="AvatarBorder" Width="36" Height="36" CornerRadius="18"
                                    Background="{StaticResource PrimaryBrush}">
                                <TextBlock x:Name="AvatarText" Text="U" FontSize="15" FontWeight="SemiBold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="AvatarBorder" Property="Background"
                                            Value="{StaticResource PrimaryDarkBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Top: Navigation icons -->
                <StackPanel Margin="0,8,0,0">
                    <!-- App logo -->
                    <Border Width="36" Height="36" CornerRadius="6"
                            Background="{StaticResource PrimaryBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="A" FontSize="18" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <RadioButton x:Name="NavFeed" Style="{StaticResource NavButton}"
                                 Content="&#xE71D;" Click="NavFeed_Click"
                                 ToolTip="Feed" />
                    <RadioButton x:Name="NavChat" Style="{StaticResource NavButton}"
                                 Content="&#xE8BD;" Click="NavChat_Click"
                                 IsChecked="True" ToolTip="Chat" />
                    <RadioButton x:Name="NavTeams" Style="{StaticResource NavButton}"
                                 Content="&#xE716;" Click="NavTeams_Click"
                                 ToolTip="Teams" />
                    <RadioButton x:Name="NavCalendar" Style="{StaticResource NavButton}"
                                 Content="&#xE787;" Click="NavCalendar_Click"
                                 ToolTip="Calendar" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- === COLUMN 1: Channel/list sidebar === -->
        <Border Grid.Column="1" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- User header -->
                <Border DockPanel.Dock="Top" Padding="14,10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <!-- Online indicator -->
                        <Ellipse DockPanel.Dock="Left" Width="8" Height="8"
                                 Fill="#4CAF50" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <StackPanel>
                            <TextBlock x:Name="UserDisplayName" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock x:Name="UserStatus" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Section header -->
                <Border DockPanel.Dock="Top" Padding="14,8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock x:Name="SidebarHeader" Text="Chats" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </Border>

                <!-- Scrollable sidebar content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Chat channel list -->
                        <ListBox x:Name="ChannelList" BorderThickness="0"
                                 SelectionChanged="ChannelList_SelectionChanged"
                                 Background="Transparent">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="14,8" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                                        Background="Transparent">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{StaticResource HoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{StaticResource PrimaryLightBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <!-- Channel type icon -->
                                        <Border DockPanel.Dock="Left" Width="32" Height="32"
                                                CornerRadius="4" Background="{StaticResource HoverBrush}"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="#" FontSize="16" FontWeight="Bold"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <!-- Channel info -->
                                        <TextBlock Text="{Binding UnreadCount}" FontSize="10"
                                                   Foreground="White" DockPanel.Dock="Right"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding UnreadCount, Converter={x:Static local:Converters.IntToVisibility}}">
                                            <TextBlock.Background>
                                                <SolidColorBrush Color="#6264A7" />
                                            </TextBlock.Background>
                                            <TextBlock.Padding>
                                                <Thickness>5,1,5,1</Thickness>
                                            </TextBlock.Padding>
                                        </TextBlock>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                                <Run Text="{Binding MemberCount}" /><Run Text=" members" />
                                            </TextBlock>
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Teams list (visible when Teams nav selected) -->
                        <ListBox x:Name="TeamList" BorderThickness="0"
                                 SelectionChanged="TeamList_SelectionChanged"
                                 Background="Transparent" Visibility="Collapsed">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="14,8" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                                        Background="Transparent">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{StaticResource HoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{StaticResource PrimaryLightBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <Border DockPanel.Dock="Left" Width="32" Height="32"
                                                CornerRadius="4" Background="{StaticResource PrimaryBrush}"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Name, Converter={x:Static local:Converters.FirstChar}}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                                <Run Text="{Binding MemberCount}" /><Run Text=" members" />
                                            </TextBlock>
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Team channels (shown when a team is selected) -->
                        <Border x:Name="TeamChannelsBorder" Padding="8,4,8,8" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="TeamChannelsHeader" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBrush}" Margin="8,4,0,4" />
                                <ListBox x:Name="TeamChannelList" BorderThickness="0"
                                         SelectionChanged="TeamChannelList_SelectionChanged"
                                         Background="Transparent">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="10,6" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                                                Background="Transparent" CornerRadius="4">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background"
                                                                        Value="{StaticResource HoverBrush}" />
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Bd" Property="Background"
                                                                        Value="{StaticResource PrimaryLightBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel>
                                                <TextBlock FontSize="12" Foreground="{StaticResource TextPrimaryBrush}">
                                                    <Run Text="# " Foreground="{StaticResource TextSecondaryBrush}" /><Run Text="{Binding Name}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding UnreadCount}" FontSize="10"
                                                           Foreground="White" Background="#6264A7"
                                                           Padding="4,1" HorizontalAlignment="Right"
                                                           Visibility="{Binding UnreadCount, Converter={x:Static local:Converters.IntToVisibility}}" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <!-- Feed items in sidebar (visible when Feed nav selected) -->
                        <ItemsControl x:Name="FeedList" Visibility="Collapsed" Margin="4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4,2" Padding="12,8" Background="White"
                                            CornerRadius="4" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" Cursor="Hand">
                                        <StackPanel>
                                            <DockPanel>
                                                <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                                         VerticalAlignment="Center"
                                                         Fill="{StaticResource PrimaryBrush}"
                                                         Visibility="{Binding IsReadInverted, Converter={x:Static local:Converters.BoolToVisibility}}" />
                                                <TextBlock Text="{Binding ActorName}" FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding CreatedAt}" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding Message}" FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0" />
                                            <TextBlock FontSize="11" Foreground="{StaticResource PrimaryBrush}"
                                                       Margin="0,2,0,0">
                                                <Run Text="in " /><Run Text="{Binding ChannelName}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Calendar events list (visible when Calendar nav selected) -->
                        <ItemsControl x:Name="CalendarList" Visibility="Collapsed" Margin="4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4,2" Padding="12,8" Background="White"
                                            CornerRadius="4" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding TimeRange}" FontSize="11"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0"
                                                       Visibility="{Binding Description, Converter={x:Static local:Converters.StringToVisibility}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- === COLUMN 2: Main content area === -->
        <Grid Grid.Column="2">
            <!-- Empty state -->
            <StackPanel x:Name="EmptyState" VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Border Width="64" Height="64" CornerRadius="32"
                        Background="{StaticResource PrimaryLightBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets"
                               FontSize="28" Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="EmptyStateTitle" Text="Welcome to Agora" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="EmptyStateSubtitle" Text="Select a chat" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>

            <!-- Feed view (3-column layout in main content area) -->
            <Border x:Name="FeedView" Visibility="Collapsed" Background="{StaticResource BackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <!-- Feed header -->
                    <Border Grid.Row="0" Padding="16,12" Background="White"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Click="FeedRefresh_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="8,4" ToolTip="Refresh">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                            </Button>
                            <!-- Unread / All toggle -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,12,0"
                                        VerticalAlignment="Center">
                                <RadioButton x:Name="FeedFilterAll" Content="Alle" IsChecked="True"
                                             GroupName="FeedFilter" Margin="0,0,4,0"
                                             Click="FeedFilterAll_Click"
                                             Style="{StaticResource {x:Type ToggleButton}}"
                                             Padding="12,4" FontSize="12" Cursor="Hand" />
                                <RadioButton x:Name="FeedFilterUnread" Content="Ungelesen"
                                             GroupName="FeedFilter" Margin="4,0,0,0"
                                             Click="FeedFilterUnread_Click"
                                             Style="{StaticResource {x:Type ToggleButton}}"
                                             Padding="12,4" FontSize="12" Cursor="Hand" />
                            </StackPanel>
                            <TextBlock x:Name="FeedTitle" Text="Feed" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                    <!-- Feed grid (3 columns) -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12">
                        <ItemsControl x:Name="FeedMainList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="6" Padding="14,12" Background="White"
                                            CornerRadius="6" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" Cursor="Hand">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="4" Opacity="0.08" ShadowDepth="1" />
                                        </Border.Effect>
                                        <StackPanel>
                                            <DockPanel>
                                                <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                                         VerticalAlignment="Center"
                                                         Fill="{StaticResource PrimaryBrush}"
                                                         Visibility="{Binding IsReadInverted, Converter={x:Static local:Converters.BoolToVisibility}}" />
                                                <TextBlock Text="{Binding ActorName}" FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding Message}" FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" MaxHeight="60"
                                                       Margin="0,6,0,0" />
                                            <DockPanel Margin="0,8,0,0">
                                                <TextBlock FontSize="11" Foreground="{StaticResource PrimaryBrush}">
                                                    <Run Text="in " /><Run Text="{Binding ChannelName}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding CreatedAt}" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right" />
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Settings view -->
            <Border x:Name="SettingsView" Visibility="Collapsed" Padding="32">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="480">
                        <TextBlock x:Name="SettingsTitle" Text="Settings" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24" />

                        <!-- Display Name -->
                        <TextBlock x:Name="SettingsDisplayNameLabel" Text="Display Name" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox x:Name="SettingsDisplayName" Padding="8" FontSize="13" Margin="0,0,0,16"
                                 BorderBrush="{StaticResource BorderBrush}" />

                        <!-- Email -->
                        <TextBlock x:Name="SettingsEmailLabel" Text="Email" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox x:Name="SettingsEmail" Padding="8" FontSize="13" Margin="0,0,0,16"
                                 BorderBrush="{StaticResource BorderBrush}" />

                        <!-- Language -->
                        <TextBlock x:Name="SettingsLanguageLabel" Text="Language" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <ComboBox x:Name="SettingsLanguage" Padding="8" FontSize="13" Margin="0,0,0,24"
                                  BorderBrush="{StaticResource BorderBrush}" />

                        <Separator Margin="0,0,0,24" />

                        <!-- Change Password -->
                        <TextBlock x:Name="SettingsPasswordHeader" Text="Change Password" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" />

                        <TextBlock x:Name="SettingsCurrentPasswordLabel" Text="Current Password" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <PasswordBox x:Name="SettingsCurrentPassword" Padding="8" FontSize="13" Margin="0,0,0,16"
                                     BorderBrush="{StaticResource BorderBrush}" />

                        <TextBlock x:Name="SettingsNewPasswordLabel" Text="New Password" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <PasswordBox x:Name="SettingsNewPassword" Padding="8" FontSize="13" Margin="0,0,0,24"
                                     BorderBrush="{StaticResource BorderBrush}" />

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="SettingsSaveBtn" Content="Save" Style="{StaticResource PrimaryButton}"
                                    Padding="20,8" Click="SettingsSave_Click" Margin="0,0,12,0" />
                            <Button x:Name="SettingsCancelBtn" Content="Cancel" Padding="20,8"
                                    Click="SettingsCancel_Click"
                                    Background="#E0E0E0" Foreground="#333333" BorderThickness="0" />
                        </StackPanel>

                        <!-- Status message -->
                        <TextBlock x:Name="SettingsStatus" FontSize="12" Margin="0,12,0,0"
                                   TextWrapping="Wrap" Visibility="Collapsed" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Chat view -->
            <Grid x:Name="ChatView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Chat header -->
                <Border Grid.Row="0" Padding="16,10" Background="White"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <!-- Video call button -->
                        <Button x:Name="VideoCallBtn" DockPanel.Dock="Right" Cursor="Hand"
                                Click="VideoCall_Click" ToolTip="Video Call"
                                Background="Transparent" BorderThickness="0" Padding="8,4">
                            <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Button>
                        <!-- File upload button -->
                        <Button x:Name="FileUploadHeaderBtn" DockPanel.Dock="Right" Cursor="Hand"
                                Click="FileUpload_Click" ToolTip="Upload File"
                                Background="Transparent" BorderThickness="0" Padding="8,4">
                            <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Button>
                        <StackPanel>
                            <TextBlock x:Name="ChatTitle" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock x:Name="ChatSubtitle" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Messages -->
                <ScrollViewer Grid.Row="1" x:Name="MessageScroll"
                              VerticalScrollBarVisibility="Auto" Padding="16,8"
                              Background="{StaticResource BackgroundBrush}">
                    <ItemsControl x:Name="MessageList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,2" Padding="10,6"
                                        CornerRadius="6" Cursor="Hand"
                                        Background="{Binding BubbleColor}"
                                        HorizontalAlignment="{Binding BubbleAlignment}"
                                        MaxWidth="600"
                                        MouseRightButtonUp="Message_RightClick"
                                        Tag="{Binding Id}">
                                    <StackPanel>
                                        <!-- Reply quote -->
                                        <Border Margin="0,0,0,4" Padding="6,4"
                                                BorderBrush="{StaticResource PrimaryBrush}"
                                                BorderThickness="3,0,0,0" Background="#E8E8E8"
                                                CornerRadius="2"
                                                Visibility="{Binding ReplyToSender, Converter={x:Static local:Converters.StringToVisibility}}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding ReplyToSender}" FontSize="11"
                                                           FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" />
                                                <TextBlock Text="{Binding ReplyToContent}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis" MaxHeight="20" />
                                            </StackPanel>
                                        </Border>

                                        <!-- Header: sender + time -->
                                        <DockPanel>
                                            <TextBlock FontSize="12" Foreground="{StaticResource PrimaryBrush}">
                                                <Run Text="{Binding SenderName}" FontWeight="SemiBold" />
                                                <Run Text="{Binding EditedIndicator, Mode=OneWay}" FontStyle="Italic"
                                                     Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding CreatedAt}" FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center" Margin="12,0,0,0" />
                                        </DockPanel>

                                        <!-- Content: plain text (for non-HTML messages) -->
                                        <emoji:TextBlock Text="{Binding Content}" FontSize="13"
                                                   TextWrapping="Wrap" Margin="0,3,0,0"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Visibility="{Binding IsPlainTextMessage, Converter={x:Static local:Converters.BoolToVisibility}}" />

                                        <!-- Content: HTML/rich messages rendered as formatted text -->
                                        <RichTextBox helpers:RichTextBoxHelper.Html="{Binding Content}"
                                                     IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                     Margin="0,3,0,0" Padding="0" IsTabStop="False"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     Visibility="{Binding IsRichMessage, Converter={x:Static local:Converters.BoolToVisibility}}" />

                                        <!-- Inline image -->
                                        <Border Margin="0,4,0,0" CornerRadius="6"
                                                Visibility="{Binding HasImage, Converter={x:Static local:Converters.BoolToVisibility}}"
                                                Cursor="Hand" MouseLeftButtonUp="FileAttachment_Click"
                                                Tag="{Binding FileReferenceId}">
                                            <Border.Clip>
                                                <RectangleGeometry RadiusX="6" RadiusY="6"
                                                                   Rect="0,0,300,300" />
                                            </Border.Clip>
                                            <Image Source="{Binding ImageSource}" MaxWidth="300" MaxHeight="300"
                                                   Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>

                                        <!-- File attachment (non-image files) -->
                                        <Border Margin="0,4,0,0" Padding="6,4"
                                                Background="#E0E0E0" CornerRadius="4"
                                                Visibility="{Binding IsNonImageFile, Converter={x:Static local:Converters.BoolToVisibility}}"
                                                Cursor="Hand" MouseLeftButtonUp="FileAttachment_Click"
                                                Tag="{Binding FileReferenceId}">
                                            <DockPanel>
                                                <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14" Foreground="{StaticResource PrimaryBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding Content}" FontSize="12"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>
                                        </Border>

                                        <!-- Reactions -->
                                        <ItemsControl ItemsSource="{Binding ReactionGroups}" Margin="0,3,0,0"
                                                      Visibility="{Binding HasReactions, Converter={x:Static local:Converters.BoolToVisibility}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,4,0" Padding="4,1"
                                                            Background="#E0E0E0" CornerRadius="10"
                                                            Cursor="Hand"
                                                            MouseLeftButtonUp="Reaction_Click"
                                                            Tag="{Binding Emoji}">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <emoji:TextBlock Text="{Binding Emoji}" FontSize="12" VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding Count}" Foreground="{StaticResource TextSecondaryBrush}"
                                                                       FontSize="10" VerticalAlignment="Center" Margin="2,0,0,0" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Reply indicator -->
                <Border Grid.Row="2" x:Name="ReplyBar" Padding="10,6" Background="White"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Visibility="Collapsed">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="&#x2715;" FontSize="14"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Click="ReplyCancel_Click" Padding="6,0"
                                Foreground="{StaticResource TextSecondaryBrush}" />
                        <StackPanel>
                            <TextBlock FontSize="11" Foreground="{StaticResource PrimaryBrush}">
                                <Run Text="Replying to " /><Run x:Name="ReplyToName" FontWeight="SemiBold" />
                            </TextBlock>
                            <TextBlock x:Name="ReplyToPreview" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Typing indicator -->
                <Border Grid.Row="3" x:Name="TypingBar" Padding="12,4" Background="White"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TypingText" FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Border>

                <!-- Message input area with WYSIWYG editor -->
                <Border Grid.Row="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Background="White">
                    <!-- WebView2 WYSIWYG editor (primary) -->
                    <Grid x:Name="RichEditorContainer" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <wv2:WebView2 x:Name="EditorWebView" Grid.Column="0"
                                      MinHeight="90" MaxHeight="180" />
                        <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Bottom" Margin="4,4,8,4">
                            <Button Click="FileUpload_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="6,4" Margin="0,2" ToolTip="Attach File">
                                <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                            </Button>
                            <Button Click="EmojiButton_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="6,4" Margin="0,2" ToolTip="Emoji">
                                <TextBlock Text="&#xE76E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                            </Button>
                            <Button x:Name="EditorSendButton" Style="{StaticResource PrimaryButton}"
                                    Click="EditorSendButton_Click"
                                    Height="34" Width="34" Padding="0" Margin="0,2">
                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Fallback: plain TextBox editor -->
                    <Border x:Name="PlainEditorContainer" Padding="12,8">
                    <DockPanel>
                        <!-- Send button -->
                        <Button x:Name="SendButton" DockPanel.Dock="Right"
                                Style="{StaticResource PrimaryButton}"
                                Click="SendButton_Click" Margin="8,0,0,0"
                                Height="34" Padding="16,0">
                            <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" />
                        </Button>
                        <!-- Attach file button -->
                        <Button DockPanel.Dock="Right" Click="FileUpload_Click"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Padding="6,0" Margin="4,0" ToolTip="Attach File">
                            <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Button>
                        <!-- Emoji button -->
                        <Button DockPanel.Dock="Right"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Padding="6,0" Click="EmojiButton_Click" ToolTip="Emoji">
                            <TextBlock Text="&#xE76E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Button>
                        <TextBox x:Name="MessageInput" Padding="8,6" FontSize="13"
                                 BorderBrush="{StaticResource BorderBrush}" VerticalAlignment="Center"
                                 KeyDown="MessageInput_KeyDown"
                                 AcceptsReturn="False" />
                    </DockPanel>
                    </Border>
                </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Video call overlay (WebView2) -->
        <Grid x:Name="VideoCallView" Grid.Column="2" Visibility="Collapsed"
              Background="#1a1a1a" Panel.ZIndex="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Padding="12,8" Background="#252525"
                    BorderBrush="#333" BorderThickness="0,0,0,1">
                <DockPanel>
                    <Button DockPanel.Dock="Right" x:Name="VideoCallLeaveBtn"
                            Click="VideoCallLeave_Click"
                            Background="#c4314b" Foreground="White" Padding="16,6"
                            BorderThickness="0" Cursor="Hand" FontSize="12" />
                    <TextBlock x:Name="VideoCallTitle" FontSize="14" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center" Margin="4,0,0,0" />
                </DockPanel>
            </Border>
            <wv2:WebView2 x:Name="VideoWebView" Grid.Row="1" />
        </Grid>

        <!-- Toast notification popup -->
        <Border x:Name="ToastBorder" Grid.Column="2"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="16,16" Padding="12,10" CornerRadius="8"
                Background="#323232" Visibility="Collapsed"
                MaxWidth="350">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Opacity="0.3" ShadowDepth="4" />
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="ToastTitle" FontSize="12" FontWeight="SemiBold"
                           Foreground="White" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ToastBody" FontSize="11" Foreground="#CCCCCC"
                           TextWrapping="Wrap" MaxHeight="40"
                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- Event Reminder Popup -->
        <Border x:Name="ReminderBorder" Grid.Column="2"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="16,16" Padding="16,14" CornerRadius="10"
                Background="White" Visibility="Collapsed"
                MaxWidth="340" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="3,0,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" Opacity="0.25" ShadowDepth="6" />
            </Border.Effect>
            <StackPanel>
                <emoji:TextBlock Text="&#x1F514;" FontSize="22" Margin="0,0,0,6" />
                <TextBlock x:Name="ReminderTitle" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ReminderTime" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,6" />
                <TextBlock x:Name="ReminderCountdown" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="ReminderJoinBtn" Style="{StaticResource PrimaryButton}"
                            Padding="14,6" Click="ReminderJoin_Click" Margin="0,0,8,0"
                            Visibility="Collapsed" />
                    <Button x:Name="ReminderDismissBtn" Padding="14,6"
                            Click="ReminderDismiss_Click"
                            Background="#E0E0E0" Foreground="#333333"
                            BorderThickness="0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Message context menu -->
        <Popup x:Name="MessageContextMenu" StaysOpen="False"
               Placement="MousePoint" AllowsTransparency="True">
            <Border Background="White" CornerRadius="6" Padding="4"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.15" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel MinWidth="160">
                    <Button x:Name="CtxReply" Content="Reply" Click="CtxReply_Click"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="12,6" Cursor="Hand" />
                    <Button x:Name="CtxEdit" Content="Edit" Click="CtxEdit_Click"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="12,6" Cursor="Hand" />
                    <Button x:Name="CtxDelete" Content="Delete" Click="CtxDelete_Click"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="12,6" Cursor="Hand"
                            Foreground="Red" />
                    <Separator Margin="4,2" />
                    <StackPanel Orientation="Horizontal" Margin="8,4">
                        <Button Click="CtxReaction_Click" Tag="&#x1F44D;"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,2" Cursor="Hand">
                            <emoji:TextBlock Text="&#x1F44D;" FontSize="18" />
                        </Button>
                        <Button Click="CtxReaction_Click" Tag="&#x2764;&#xFE0F;"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,2" Cursor="Hand">
                            <emoji:TextBlock Text="&#x2764;" FontSize="18" />
                        </Button>
                        <Button Click="CtxReaction_Click" Tag="&#x1F602;"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,2" Cursor="Hand">
                            <emoji:TextBlock Text="&#x1F602;" FontSize="18" />
                        </Button>
                        <Button Click="CtxReaction_Click" Tag="&#x1F389;"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,2" Cursor="Hand">
                            <emoji:TextBlock Text="&#x1F389;" FontSize="18" />
                        </Button>
                        <Button Click="CtxReaction_Click" Tag="&#x1F44E;"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,2" Cursor="Hand">
                            <emoji:TextBlock Text="&#x1F44E;" FontSize="18" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Emoji picker popup -->
        <Popup x:Name="EmojiPicker" StaysOpen="False"
               Placement="Top" AllowsTransparency="True">
            <Border Background="White" CornerRadius="8" Padding="8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.15" ShadowDepth="2" />
                </Border.Effect>
                <WrapPanel MaxWidth="280">
                    <Button Click="EmojiPick_Click" Tag="&#x1F44D;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F44D;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F44E;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F44E;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x2764;&#xFE0F;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x2764;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F602;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F602;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F389;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F389;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F60A;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F60A;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F914;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F914;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F44F;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F44F;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F525;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F525;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x2705;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x2705;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x274C;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x274C;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F4AF;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F4AF;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F440;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F440;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F64F;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F64F;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F680;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F680;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x2B50;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x2B50;" FontSize="22" /></Button>
                </WrapPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
