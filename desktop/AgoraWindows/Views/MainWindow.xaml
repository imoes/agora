<Window x:Class="AgoraWindows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AgoraWindows.Views"
        xmlns:helpers="clr-namespace:AgoraWindows.Helpers"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Agora" Width="1100" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Closing="Window_Closing"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Dark icon sidebar -->
            <ColumnDefinition Width="52" />
            <!-- Channel/list sidebar -->
            <ColumnDefinition Width="260" />
            <!-- Main content area -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- === COLUMN 0: Dark icon sidebar === -->
        <Border Grid.Column="0" Background="{StaticResource SidebarDarkBrush}">
            <DockPanel>
                <!-- Bottom: User avatar -->
                <Button DockPanel.Dock="Bottom" Click="SettingsButton_Click"
                        Width="36" Height="36" Margin="0,0,0,12" Cursor="Hand"
                        ToolTip="Settings">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="AvatarBorder" Width="36" Height="36" CornerRadius="18"
                                    Background="{StaticResource PrimaryBrush}">
                                <TextBlock x:Name="AvatarText" Text="U" FontSize="15" FontWeight="SemiBold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="AvatarBorder" Property="Background"
                                            Value="{StaticResource PrimaryDarkBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Top: Navigation icons -->
                <StackPanel Margin="0,8,0,0">
                    <!-- App logo -->
                    <Border Width="36" Height="36" CornerRadius="6"
                            Background="{StaticResource PrimaryBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="A" FontSize="18" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <Grid>
                        <RadioButton x:Name="NavFeed" Style="{StaticResource NavButton}"
                                     Content="&#xE71D;" Click="NavFeed_Click"
                                     ToolTip="Feed" />
                        <TextBlock x:Name="NavFeedBadge" Visibility="Collapsed"
                                   FontFamily="Segoe UI" FontSize="9" FontWeight="Bold"
                                   Foreground="White" Background="#E74856"
                                   Padding="4,1" MinWidth="16" TextAlignment="Center"
                                   HorizontalAlignment="Right" VerticalAlignment="Top"
                                   Margin="0,4,4,0" IsHitTestVisible="False" />
                    </Grid>
                    <Grid>
                        <RadioButton x:Name="NavChat" Style="{StaticResource NavButton}"
                                     Content="&#xE8BD;" Click="NavChat_Click"
                                     IsChecked="True" ToolTip="Chat" />
                        <TextBlock x:Name="NavChatBadge" Visibility="Collapsed"
                                   FontFamily="Segoe UI" FontSize="9" FontWeight="Bold"
                                   Foreground="White" Background="#E74856"
                                   Padding="4,1" MinWidth="16" TextAlignment="Center"
                                   HorizontalAlignment="Right" VerticalAlignment="Top"
                                   Margin="0,4,4,0" IsHitTestVisible="False" />
                    </Grid>
                    <Grid>
                        <RadioButton x:Name="NavTeams" Style="{StaticResource NavButton}"
                                     Content="&#xE716;" Click="NavTeams_Click"
                                     ToolTip="Teams" />
                        <TextBlock x:Name="NavTeamsBadge" Visibility="Collapsed"
                                   FontFamily="Segoe UI" FontSize="9" FontWeight="Bold"
                                   Foreground="White" Background="#E74856"
                                   Padding="4,1" MinWidth="16" TextAlignment="Center"
                                   HorizontalAlignment="Right" VerticalAlignment="Top"
                                   Margin="0,4,4,0" IsHitTestVisible="False" />
                    </Grid>
                    <RadioButton x:Name="NavCalendar" Style="{StaticResource NavButton}"
                                 Content="&#xE787;" Click="NavCalendar_Click"
                                 ToolTip="Calendar" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- === COLUMN 1: Channel/list sidebar === -->
        <Border Grid.Column="1" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- User header -->
                <Border DockPanel.Dock="Top" Padding="14,10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <!-- Online indicator -->
                        <Ellipse DockPanel.Dock="Left" Width="8" Height="8"
                                 Fill="#4CAF50" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <StackPanel>
                            <TextBlock x:Name="UserDisplayName" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock x:Name="UserStatus" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Section header with new chat button -->
                <Border DockPanel.Dock="Top" Padding="14,8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <Button x:Name="NewChatBtn" DockPanel.Dock="Right" Click="NewChat_Click" Cursor="Hand"
                                Background="Transparent" BorderThickness="0"
                                Padding="6,2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                                           Foreground="{StaticResource PrimaryBrush}" />
                                <TextBlock x:Name="NewChatBtnLabel" Text="Neuer Chat" FontSize="12"
                                           Foreground="{StaticResource PrimaryBrush}" />
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="SidebarHeader" Text="Chats" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </DockPanel>
                </Border>

                <!-- Scrollable sidebar content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Chat channel list -->
                        <ListBox x:Name="ChannelList" BorderThickness="0"
                                 SelectionChanged="ChannelList_SelectionChanged"
                                 Background="Transparent">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="14,8" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                                        Background="Transparent">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{StaticResource HoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{StaticResource PrimaryLightBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <!-- Channel avatar circle (colored by name) -->
                                        <Border DockPanel.Dock="Left" Width="36" Height="36"
                                                CornerRadius="18" Margin="0,0,10,0"
                                                Background="{Binding Name, Converter={x:Static local:Converters.NameToAvatarColor}}">
                                            <TextBlock Text="{Binding Name, Converter={x:Static local:Converters.FirstChar}}"
                                                       FontSize="15" FontWeight="SemiBold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <!-- Channel info -->
                                        <StackPanel VerticalAlignment="Center">
                                            <DockPanel>
                                                <TextBlock Text="{Binding UnreadCount}" FontSize="10"
                                                           Foreground="White" DockPanel.Dock="Right"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding UnreadCount, Converter={x:Static local:Converters.IntToVisibility}}">
                                                    <TextBlock.Background>
                                                        <SolidColorBrush Color="#6264A7" />
                                                    </TextBlock.Background>
                                                    <TextBlock.Padding>
                                                        <Thickness>5,1,5,1</Thickness>
                                                    </TextBlock.Padding>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Name}" FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </DockPanel>
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="{Binding MemberCountDisplay}" />
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Teams header with create button -->
                        <DockPanel x:Name="TeamsHeader" Margin="14,6,8,2" Visibility="Collapsed">
                            <TextBlock Text="Teams" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right" Click="NewTeamButton_Click" Cursor="Hand"
                                    HorizontalAlignment="Right" Padding="4,2"
                                    Background="Transparent" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock x:Name="NewTeamBtnLabel" Text="Neues Team" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </Button>
                        </DockPanel>

                        <!-- Teams tree (visible when Teams nav selected) -->
                        <ItemsControl x:Name="TeamTreeList" Visibility="Collapsed" />

                        <!-- Feed sidebar info (visible when Feed nav selected) -->
                        <StackPanel x:Name="FeedSidebarInfo" Visibility="Collapsed" Margin="14,8">
                            <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="28" Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,16,0,8" />
                            <TextBlock Text="Aktivitaeten" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,8" />
                            <TextBlock x:Name="FeedSidebarCount" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                       TextAlignment="Center" />
                        </StackPanel>

                        <!-- Calendar events list (visible when Calendar nav selected) -->
                        <ItemsControl x:Name="CalendarList" Visibility="Collapsed" Margin="4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4,2" Padding="12,8" Background="White"
                                            CornerRadius="4" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" Cursor="Hand"
                                            MouseLeftButtonUp="CalendarEventCard_Click">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding TimeRange}" FontSize="11"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       Margin="0,2,0,0" />
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0"
                                                       Visibility="{Binding Description, Converter={x:Static local:Converters.StringToVisibility}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- === COLUMN 2: Main content area === -->
        <Grid x:Name="MainContentArea" Grid.Column="2">
            <!-- Empty state -->
            <StackPanel x:Name="EmptyState" VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Border Width="64" Height="64" CornerRadius="32"
                        Background="{StaticResource PrimaryLightBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets"
                               FontSize="28" Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="EmptyStateTitle" Text="Welcome to Agora" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="EmptyStateSubtitle" Text="Select a chat" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>

            <!-- Team Detail view -->
            <Border x:Name="TeamDetailView" Visibility="Collapsed" Background="{StaticResource BackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="20,16">
                        <DockPanel>
                            <StackPanel>
                                <TextBlock x:Name="TeamDetailTitle" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock x:Name="TeamDetailSubtitle" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <Button x:Name="TeamDetailLeaveBtn" DockPanel.Dock="Right"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Padding="12,6" Margin="8,0,0,0" Cursor="Hand"
                                    Background="Transparent" BorderThickness="1"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    Click="TeamDetailLeave_Click">
                                <TextBlock x:Name="TeamDetailLeaveBtnText" Text="Leave Team" FontSize="12"
                                           Foreground="#E74856" />
                            </Button>
                        </DockPanel>
                    </Border>

                    <!-- Tab control -->
                    <TabControl x:Name="TeamDetailTabs" Grid.Row="1" Margin="0">
                        <!-- Channels tab -->
                        <TabItem x:Name="TeamDetailChannelsTab" Header="Channels">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="TeamDetailChannelsList" Margin="8" />
                            </ScrollViewer>
                        </TabItem>

                        <!-- Members tab -->
                        <TabItem x:Name="TeamDetailMembersTab" Header="Members">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Search to add members -->
                                <StackPanel Grid.Row="0" Margin="12,8">
                                    <TextBox x:Name="TeamDetailMemberSearch" Padding="8,6"
                                             TextChanged="TeamDetailMemberSearch_Changed" />
                                    <StackPanel x:Name="TeamDetailSearchResults" Margin="0,4,0,0" />
                                </StackPanel>

                                <!-- Members list -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="TeamDetailMembersList" Margin="8,0" />
                                </ScrollViewer>
                            </Grid>
                        </TabItem>

                        <!-- Files tab -->
                        <TabItem x:Name="TeamDetailFilesTab" Header="Files">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="TeamDetailFilesList" Margin="8" />
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <!-- Feed view (3-column layout in main content area) -->
            <Border x:Name="FeedView" Visibility="Collapsed" Background="{StaticResource BackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <!-- Feed header -->
                    <Border Grid.Row="0" Padding="16,12" Background="White"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Click="FeedRefresh_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="8,4" ToolTip="Refresh">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                            </Button>
                            <!-- Unread / All toggle -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,12,0"
                                        VerticalAlignment="Center">
                                <RadioButton x:Name="FeedFilterAll" Content="Alle"
                                             GroupName="FeedFilter" Margin="0,0,4,0"
                                             Click="FeedFilterAll_Click"
                                             Style="{StaticResource {x:Type ToggleButton}}"
                                             Padding="12,4" FontSize="12" Cursor="Hand" />
                                <RadioButton x:Name="FeedFilterUnread" Content="Ungelesen" IsChecked="True"
                                             GroupName="FeedFilter" Margin="4,0,0,0"
                                             Click="FeedFilterUnread_Click"
                                             Style="{StaticResource {x:Type ToggleButton}}"
                                             Padding="12,4" FontSize="12" Cursor="Hand" />
                            </StackPanel>
                            <TextBlock x:Name="FeedTitle" Text="Feed" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                    <!-- Feed list (Frontend-like single column) -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="White">
                        <ItemsControl x:Name="FeedMainList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10" Background="White" Cursor="Hand"
                                            MouseLeftButtonUp="FeedItem_Click"
                                            Tag="{Binding ChannelId}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#FFF0F0F0" />
                                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                                <Setter Property="Margin" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsReadInverted}" Value="True">
                                                        <Setter Property="Background" Value="#FFF0F0FF" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                        <Setter Property="BorderThickness" Value="3,0,0,1" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="36" Height="36" CornerRadius="18"
                                                    Margin="0,0,10,0" VerticalAlignment="Top"
                                                    Background="{Binding ActorName, Converter={x:Static local:Converters.NameToAvatarColor}}">
                                                <TextBlock Text="{Binding ActorName, Converter={x:Static local:Converters.FirstChar}}"
                                                           FontSize="13" FontWeight="SemiBold" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis">
                                                    <Run Text="{Binding ActorName}" FontWeight="SemiBold" />
                                                    <Run Text=" in " Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <Run Text="{Binding ChannelName}" Foreground="{StaticResource TextSecondaryBrush}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding Message}" FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="2" Text="{Binding FormattedTime}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Top" Margin="8,0,0,0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Calendar view (main content area) -->
            <Border x:Name="CalendarView" Visibility="Collapsed" Background="{StaticResource BackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <!-- Calendar header -->
                    <Border Grid.Row="0" Padding="16,12" Background="White"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Click="CalendarNewEvent_Click"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="12,6" Margin="8,0,0,0" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock x:Name="CalendarNewEventBtn" Text="Neuer Termin" FontSize="12" />
                                </StackPanel>
                            </Button>
                            <Button DockPanel.Dock="Right" Click="CalendarConfig_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="8,4" ToolTip="Kalender Konfiguration" Margin="4,0,0,0">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                            </Button>
                            <Button DockPanel.Dock="Right" Click="CalendarRefresh_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="8,4" ToolTip="Refresh">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                            </Button>
                            <TextBlock x:Name="CalendarViewTitle" Text="Kalender" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                    <!-- Calendar body: split view [mini cal + events | week grid] -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left panel: mini calendar + event list -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="8">
                            <StackPanel>
                                <Calendar x:Name="WpfCalendar" SelectionMode="SingleDate"
                                          IsTodayHighlighted="True"
                                          SelectedDatesChanged="WpfCalendar_SelectedDatesChanged"
                                          DisplayDateChanged="WpfCalendar_DisplayDateChanged"
                                          HorizontalAlignment="Left" Margin="0,0,0,12" />
                                <Separator Margin="0,0,0,8" />
                                <TextBlock x:Name="CalendarDayLabel" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="4,0,0,8" />
                                <ItemsControl x:Name="CalendarDayEventList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8" Padding="14,12" Background="White"
                                                CornerRadius="6" BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1" Cursor="Hand"
                                                MouseLeftButtonUp="CalendarEventCard_Click">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="4" Opacity="0.08" ShadowDepth="1" />
                                            </Border.Effect>
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding TimeRange}" FontSize="12"
                                                               Foreground="{StaticResource PrimaryBrush}"
                                                               DockPanel.Dock="Right" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Title}" FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DockPanel>
                                                <TextBlock Text="{Binding Location}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,4,0,0"
                                                           Visibility="{Binding Location, Converter={x:Static local:Converters.StringToVisibility}}" />
                                                <TextBlock Text="{Binding Description}" FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" MaxHeight="40"
                                                           Margin="0,4,0,0"
                                                           Visibility="{Binding Description, Converter={x:Static local:Converters.StringToVisibility}}" />
                                                <Button Margin="0,6,0,0" Padding="10,4"
                                                        HorizontalAlignment="Left"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Click="CalendarEventJoin_Click"
                                                        Tag="{Binding ChannelId}"
                                                        Visibility="{Binding ChannelId, Converter={x:Static local:Converters.StringToVisibility}}">
                                                    <TextBlock Text="Video Call beitreten" FontSize="11" />
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                                <TextBlock x:Name="CalendarEmptyDay" Text="Keine Termine an diesem Tag"
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="4,8,0,0" Visibility="Collapsed" />
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Vertical separator -->
                        <GridSplitter Grid.Column="1" Width="1" Background="{StaticResource BorderBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Stretch" />

                        <!-- Right panel: Week grid view -->
                        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Week day headers -->
                                <Grid x:Name="WeekHeaderGrid" Background="#FAFAFA"
                                      Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Time column spacer -->
                                    <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,1" />
                                    <Border Grid.Column="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,1" Padding="8,8">
                                        <TextBlock x:Name="WeekDay1" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Border>
                                    <Border Grid.Column="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,1" Padding="8,8">
                                        <TextBlock x:Name="WeekDay2" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Border>
                                    <Border Grid.Column="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,1" Padding="8,8">
                                        <TextBlock x:Name="WeekDay3" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Border>
                                    <Border Grid.Column="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,1" Padding="8,8">
                                        <TextBlock x:Name="WeekDay4" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Border>
                                    <Border Grid.Column="5" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,8">
                                        <TextBlock x:Name="WeekDay5" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Border>
                                </Grid>

                                <!-- Time rows (7:00 - 19:00) -->
                                <Grid x:Name="WeekTimeGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Rows are generated in code-behind -->
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                </Grid>
                </Grid>
            </Border>

            <!-- New Event dialog overlay -->
            <Border x:Name="NewEventOverlay" Visibility="Collapsed"
                    Background="#80000000" Panel.ZIndex="5">
                <Border Background="White" CornerRadius="8" Padding="24"
                        MaxWidth="480" MaxHeight="560"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" Opacity="0.3" ShadowDepth="4" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Neuer Termin" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" />
                        <!-- Title -->
                        <TextBlock Text="Titel" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox x:Name="NewEventTitle" Padding="8" FontSize="13" Margin="0,0,0,12"
                                 BorderBrush="{StaticResource BorderBrush}" />
                        <!-- Description -->
                        <TextBlock Text="Beschreibung" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox x:Name="NewEventDescription" Padding="8" FontSize="13" Margin="0,0,0,12"
                                 BorderBrush="{StaticResource BorderBrush}" AcceptsReturn="True"
                                 TextWrapping="Wrap" Height="60" VerticalScrollBarVisibility="Auto" />
                        <!-- Location -->
                        <TextBlock Text="Ort" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox x:Name="NewEventLocation" Padding="8" FontSize="13" Margin="0,0,0,12"
                                 BorderBrush="{StaticResource BorderBrush}" />
                        <!-- All day -->
                        <CheckBox x:Name="NewEventAllDay" Content="Ganztaegig" Margin="0,0,0,12"
                                  FontSize="12" Checked="NewEventAllDay_Changed" Unchecked="NewEventAllDay_Changed" />
                        <!-- Start -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Startdatum" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                <DatePicker x:Name="NewEventStartDate" FontSize="13" Width="160" />
                            </StackPanel>
                            <StackPanel x:Name="NewEventStartTimePanel">
                                <TextBlock Text="Startzeit" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                <TextBox x:Name="NewEventStartTime" Padding="8" FontSize="13" Width="100"
                                         BorderBrush="{StaticResource BorderBrush}" Text="09:00" />
                            </StackPanel>
                        </StackPanel>
                        <!-- End -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Enddatum" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                <DatePicker x:Name="NewEventEndDate" FontSize="13" Width="160" />
                            </StackPanel>
                            <StackPanel x:Name="NewEventEndTimePanel">
                                <TextBlock Text="Endzeit" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                <TextBox x:Name="NewEventEndTime" Padding="8" FontSize="13" Width="100"
                                         BorderBrush="{StaticResource BorderBrush}" Text="10:00" />
                            </StackPanel>
                        </StackPanel>
                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Abbrechen" Padding="16,8" Margin="0,0,8,0"
                                    Background="#E0E0E0" Foreground="#333333" BorderThickness="0"
                                    Click="NewEventCancel_Click" Cursor="Hand" />
                            <Button Content="Erstellen" Style="{StaticResource PrimaryButton}"
                                    Padding="16,8" Click="NewEventSave_Click" Cursor="Hand" />
                        </StackPanel>
                        <TextBlock x:Name="NewEventStatus" FontSize="12" Margin="0,8,0,0"
                                   Foreground="Red" TextWrapping="Wrap" Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </Border>

            <!-- Settings view -->
            <Border x:Name="SettingsView" Visibility="Collapsed" Padding="32">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="480">
                        <TextBlock x:Name="SettingsTitle" Text="Settings" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24" />

                        <!-- Avatar Upload -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="64" Height="64" CornerRadius="32"
                                    Background="{StaticResource PrimaryBrush}" Margin="0,0,16,0">
                                <Grid>
                                    <TextBlock x:Name="SettingsAvatarInitials" Text="U" FontSize="24" FontWeight="Bold"
                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Image x:Name="SettingsAvatarImage" Stretch="UniformToFill" Visibility="Collapsed">
                                        <Image.Clip>
                                            <EllipseGeometry Center="32,32" RadiusX="32" RadiusY="32" />
                                        </Image.Clip>
                                    </Image>
                                </Grid>
                            </Border>
                            <Button x:Name="AvatarUploadBtn" Content="Upload Avatar" Padding="16,8"
                                    Click="AvatarUpload_Click" VerticalAlignment="Center"
                                    Background="#E0E0E0" Foreground="#333333" BorderThickness="0" Cursor="Hand" />
                        </StackPanel>

                        <!-- Display Name -->
                        <TextBlock x:Name="SettingsDisplayNameLabel" Text="Display Name" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox x:Name="SettingsDisplayName" Padding="8" FontSize="13" Margin="0,0,0,16"
                                 BorderBrush="{StaticResource BorderBrush}" />

                        <!-- Email -->
                        <TextBlock x:Name="SettingsEmailLabel" Text="Email" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox x:Name="SettingsEmail" Padding="8" FontSize="13" Margin="0,0,0,16"
                                 BorderBrush="{StaticResource BorderBrush}" />

                        <!-- Language -->
                        <TextBlock x:Name="SettingsLanguageLabel" Text="Language" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <ComboBox x:Name="SettingsLanguage" Padding="8" FontSize="13" Margin="0,0,0,24"
                                  BorderBrush="{StaticResource BorderBrush}" />

                        <Separator Margin="0,0,0,24" />

                        <!-- Change Password -->
                        <TextBlock x:Name="SettingsPasswordHeader" Text="Change Password" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" />

                        <TextBlock x:Name="SettingsCurrentPasswordLabel" Text="Current Password" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <PasswordBox x:Name="SettingsCurrentPassword" Padding="8" FontSize="13" Margin="0,0,0,16"
                                     BorderBrush="{StaticResource BorderBrush}" />

                        <TextBlock x:Name="SettingsNewPasswordLabel" Text="New Password" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <PasswordBox x:Name="SettingsNewPassword" Padding="8" FontSize="13" Margin="0,0,0,24"
                                     BorderBrush="{StaticResource BorderBrush}" />

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="SettingsSaveBtn" Content="Save" Style="{StaticResource PrimaryButton}"
                                    Padding="20,8" Click="SettingsSave_Click" Margin="0,0,12,0" />
                            <Button x:Name="SettingsCancelBtn" Content="Cancel" Padding="20,8"
                                    Click="SettingsCancel_Click"
                                    Background="#E0E0E0" Foreground="#333333" BorderThickness="0" />
                        </StackPanel>

                        <Separator Margin="0,24,0,24" />

                        <!-- Calendar Integration -->
                        <TextBlock Text="Kalender Integration" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" />

                        <TextBlock Text="Anbieter" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <ComboBox x:Name="CalendarProvider" Padding="8" FontSize="13" Margin="0,0,0,16"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  SelectionChanged="CalendarProvider_Changed">
                            <ComboBoxItem Content="Intern" Tag="internal" />
                            <ComboBoxItem Content="CalDAV / WebDAV" Tag="webdav" />
                            <ComboBoxItem Content="Google Calendar" Tag="google" />
                            <ComboBoxItem Content="Outlook / Exchange" Tag="outlook" />
                        </ComboBox>

                        <!-- CalDAV fields -->
                        <StackPanel x:Name="CalDavSettings" Visibility="Collapsed">
                            <TextBlock Text="CalDAV URL" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox x:Name="CalDavUrl" Padding="8" FontSize="13" Margin="0,0,0,12"
                                     BorderBrush="{StaticResource BorderBrush}" />
                            <TextBlock Text="Benutzername" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox x:Name="CalDavUsername" Padding="8" FontSize="13" Margin="0,0,0,12"
                                     BorderBrush="{StaticResource BorderBrush}" />
                            <TextBlock Text="Passwort" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <PasswordBox x:Name="CalDavPassword" Padding="8" FontSize="13" Margin="0,0,0,12"
                                         BorderBrush="{StaticResource BorderBrush}" />
                        </StackPanel>

                        <!-- Outlook fields -->
                        <StackPanel x:Name="OutlookSettings" Visibility="Collapsed">
                            <TextBlock Text="Exchange Server URL" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox x:Name="OutlookServerUrl" Padding="8" FontSize="13" Margin="0,0,0,12"
                                     BorderBrush="{StaticResource BorderBrush}" />
                            <TextBlock Text="Benutzername" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox x:Name="OutlookUsername" Padding="8" FontSize="13" Margin="0,0,0,12"
                                     BorderBrush="{StaticResource BorderBrush}" />
                            <TextBlock Text="Passwort" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <PasswordBox x:Name="OutlookPassword" Padding="8" FontSize="13" Margin="0,0,0,12"
                                         BorderBrush="{StaticResource BorderBrush}" />
                        </StackPanel>

                        <!-- Google info -->
                        <StackPanel x:Name="GoogleSettings" Visibility="Collapsed">
                            <TextBlock Text="Google Calendar wird ueber OAuth verbunden."
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,12" />
                        </StackPanel>

                        <Button x:Name="CalendarSaveBtn" Content="Kalender speichern"
                                Style="{StaticResource PrimaryButton}"
                                Padding="20,8" Click="CalendarIntegrationSave_Click"
                                Cursor="Hand" Margin="0,0,0,8" />
                        <TextBlock x:Name="CalendarIntegrationStatus" FontSize="12" Margin="0,4,0,0"
                                   Foreground="#4CAF50" Visibility="Collapsed" />

                        <!-- Status message -->
                        <TextBlock x:Name="SettingsStatus" FontSize="12" Margin="0,12,0,0"
                                   TextWrapping="Wrap" Visibility="Collapsed" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Chat view -->
            <Grid x:Name="ChatView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Chat header -->
                <Border Grid.Row="0" Padding="16,10" Background="White"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <!-- Video call button -->
                        <Button x:Name="VideoCallBtn" DockPanel.Dock="Right" Cursor="Hand"
                                Click="VideoCall_Click" ToolTip="Video Call"
                                Background="Transparent" BorderThickness="0" Padding="8,4">
                            <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Button>
                        <!-- Leave channel button -->
                        <Button x:Name="LeaveChannelBtn" DockPanel.Dock="Right" Cursor="Hand"
                                Click="LeaveChannel_Click"
                                Background="Transparent" BorderThickness="0" Padding="8,4">
                            <TextBlock Text="&#xE89B;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="#CC0000" ToolTip="Leave Channel" />
                        </Button>
                        <!-- Add member button -->
                        <Button x:Name="AddMemberBtn" DockPanel.Dock="Right" Cursor="Hand"
                                Click="AddMember_Click"
                                Background="Transparent" BorderThickness="0" Padding="8,4">
                            <TextBlock Text="&#xE8FA;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="18" Foreground="{StaticResource TextSecondaryBrush}"
                                       ToolTip="Add Member" />
                        </Button>
                        <!-- File upload button -->
                        <Button x:Name="FileUploadHeaderBtn" DockPanel.Dock="Right" Cursor="Hand"
                                Click="FileUpload_Click" ToolTip="Upload File"
                                Background="Transparent" BorderThickness="0" Padding="8,4">
                            <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Button>
                        <StackPanel>
                            <TextBlock x:Name="ChatTitle" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="ChatStatusDot" Width="8" Height="8"
                                         Margin="0,0,5,0" VerticalAlignment="Center"
                                         Visibility="Collapsed" />
                                <TextBlock x:Name="ChatSubtitle" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Messages (Teams-style flat layout) -->
                <ScrollViewer Grid.Row="1" x:Name="MessageScroll"
                              VerticalScrollBarVisibility="Auto" Padding="0,8"
                              Background="White">
                    <ItemsControl x:Name="MessageList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <!-- Day separator (shown when IsDaySeparator is true) -->
                                    <Grid Margin="16,12"
                                          Visibility="{Binding IsDaySeparator, Converter={x:Static local:Converters.BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Separator Grid.Column="0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding DaySeparatorText}"
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="12,0" />
                                        <Separator Grid.Column="2" VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- Last-read marker (shown when IsLastReadMarker is true) -->
                                    <Grid Margin="16,8"
                                          Visibility="{Binding IsLastReadMarker, Converter={x:Static local:Converters.BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Separator Grid.Column="0" VerticalAlignment="Center">
                                            <Separator.Background>
                                                <SolidColorBrush Color="#E74C3C" />
                                            </Separator.Background>
                                        </Separator>
                                        <TextBlock Grid.Column="1" Text="{Binding DaySeparatorText}"
                                                   FontSize="11" FontWeight="SemiBold" Foreground="#E74C3C"
                                                   Margin="12,0" />
                                        <Separator Grid.Column="2" VerticalAlignment="Center">
                                            <Separator.Background>
                                                <SolidColorBrush Color="#E74C3C" />
                                            </Separator.Background>
                                        </Separator>
                                    </Grid>

                                    <!-- Message row (shown when NOT day separator) -->
                                    <Border Margin="16,2,16,2" Padding="8,6"
                                            CornerRadius="4" Cursor="Hand"
                                            Background="Transparent"
                                            HorizontalAlignment="Stretch"
                                            MouseRightButtonUp="Message_RightClick"
                                            Tag="{Binding Id}"
                                            Visibility="{Binding IsNotDaySeparator, Converter={x:Static local:Converters.BoolToVisibility}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F5F5F5" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <DockPanel>
                                            <!-- Avatar circle with status dot -->
                                            <Grid DockPanel.Dock="Left" Width="40" Height="40"
                                                  Margin="0,2,6,0" VerticalAlignment="Top">
                                                <Border Width="36" Height="36"
                                                        CornerRadius="18"
                                                        Background="{Binding AvatarColor}"
                                                        HorizontalAlignment="Left" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding AvatarInitial}" FontSize="15"
                                                               FontWeight="SemiBold" Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <Ellipse Width="10" Height="10"
                                                         Fill="{Binding StatusDotColor}"
                                                         Stroke="White" StrokeThickness="2"
                                                         HorizontalAlignment="Right"
                                                         VerticalAlignment="Bottom"
                                                         Margin="0,0,2,0" />
                                            </Grid>
                                            <!-- Content column -->
                                            <StackPanel>
                                                <!-- Reply quote -->
                                                <Border Margin="0,0,0,4" Padding="6,4"
                                                        BorderBrush="{StaticResource PrimaryBrush}"
                                                        BorderThickness="3,0,0,0" Background="#F0F0F0"
                                                        CornerRadius="2"
                                                        Visibility="{Binding ReplyToSender, Converter={x:Static local:Converters.StringToVisibility}}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding ReplyToSender}" FontSize="11"
                                                                   FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" />
                                                        <TextBlock Text="{Binding ReplyToContent}" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" MaxHeight="20" />
                                                    </StackPanel>
                                                </Border>

                                                <!-- Header: sender name + time (Teams style) -->
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding SenderName}" FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                    <TextBlock Text="{Binding EditedIndicator, Mode=OneWay}" FontSize="10"
                                                               FontStyle="Italic" Margin="6,0,0,0"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding FormattedTime}" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                                </StackPanel>

                                                <!-- Content: plain text -->
                                                <emoji:TextBlock Text="{Binding Content}" FontSize="13"
                                                           TextWrapping="Wrap" Margin="0,2,0,0"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Visibility="{Binding IsPlainTextMessage, Converter={x:Static local:Converters.BoolToVisibility}}" />

                                                <!-- Content: HTML/rich messages -->
                                                <RichTextBox helpers:RichTextBoxHelper.Html="{Binding Content}"
                                                             IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                             Margin="0,2,0,0" Padding="0" IsTabStop="False"
                                                             Foreground="{StaticResource TextPrimaryBrush}"
                                                             Visibility="{Binding IsRichMessage, Converter={x:Static local:Converters.BoolToVisibility}}" />

                                                <!-- Inline image -->
                                                <Border Margin="0,4,0,0" CornerRadius="6" ClipToBounds="True"
                                                        Visibility="{Binding HasImage, Converter={x:Static local:Converters.BoolToVisibility}}"
                                                        Cursor="Hand" MouseLeftButtonUp="FileAttachment_Click"
                                                        Tag="{Binding FileReferenceId}">
                                                    <Image Source="{Binding ImageSource}" MaxWidth="300" MaxHeight="300"
                                                           Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                                </Border>

                                                <!-- File attachment -->
                                                <Border Margin="0,4,0,0" Padding="6,4"
                                                        Background="#E0E0E0" CornerRadius="4"
                                                        Visibility="{Binding IsNonImageFile, Converter={x:Static local:Converters.BoolToVisibility}}"
                                                        Cursor="Hand" MouseLeftButtonUp="FileAttachment_Click"
                                                        Tag="{Binding FileReferenceId}">
                                                    <DockPanel>
                                                        <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="14" Foreground="{StaticResource PrimaryBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                                                        <TextBlock Text="{Binding Content}" FontSize="12"
                                                                   Foreground="{StaticResource PrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center" />
                                                    </DockPanel>
                                                </Border>

                                                <!-- Reactions -->
                                                <ItemsControl ItemsSource="{Binding ReactionGroups}" Margin="0,3,0,0"
                                                              Visibility="{Binding HasReactions, Converter={x:Static local:Converters.BoolToVisibility}}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,0,4,0" Padding="4,1"
                                                                    Background="#E0E0E0" CornerRadius="10"
                                                                    Cursor="Hand"
                                                                    MouseLeftButtonUp="Reaction_Click"
                                                                    Tag="{Binding Emoji}">
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <emoji:TextBlock Text="{Binding Emoji}" FontSize="12" VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding Count}" Foreground="{StaticResource TextSecondaryBrush}"
                                                                               FontSize="10" VerticalAlignment="Center" Margin="2,0,0,0" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Reply indicator -->
                <Border Grid.Row="2" x:Name="ReplyBar" Padding="10,6" Background="White"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Visibility="Collapsed">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="&#x2715;" FontSize="14"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Click="ReplyCancel_Click" Padding="6,0"
                                Foreground="{StaticResource TextSecondaryBrush}" />
                        <StackPanel>
                            <TextBlock FontSize="11" Foreground="{StaticResource PrimaryBrush}">
                                <Run Text="Replying to " /><Run x:Name="ReplyToName" FontWeight="SemiBold" />
                            </TextBlock>
                            <TextBlock x:Name="ReplyToPreview" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Typing indicator -->
                <Border Grid.Row="3" x:Name="TypingBar" Padding="12,4" Background="White"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TypingText" FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Border>

                <!-- Message input area with WYSIWYG editor -->
                <Border Grid.Row="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Background="White">
                    <!-- WebView2 WYSIWYG editor (primary) -->
                    <Grid x:Name="RichEditorContainer" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <wv2:WebView2 x:Name="EditorWebView" Grid.Column="0"
                                      MinHeight="90" MaxHeight="180" />
                        <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Bottom" Margin="4,4,8,4">
                            <Button Click="FileUpload_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="6,4" Margin="0,2" ToolTip="Attach File">
                                <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                            </Button>
                            <Button Click="EmojiButton_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Padding="6,4" Margin="0,2" ToolTip="Emoji">
                                <TextBlock Text="&#xE76E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                            </Button>
                            <Button x:Name="EditorSendButton" Style="{StaticResource PrimaryButton}"
                                    Click="EditorSendButton_Click"
                                    Height="34" Width="34" Padding="0" Margin="0,2">
                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Fallback: plain TextBox editor -->
                    <Border x:Name="PlainEditorContainer" Padding="12,8">
                    <DockPanel>
                        <!-- Send button -->
                        <Button x:Name="SendButton" DockPanel.Dock="Right"
                                Style="{StaticResource PrimaryButton}"
                                Click="SendButton_Click" Margin="8,0,0,0"
                                Height="34" Padding="16,0">
                            <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" />
                        </Button>
                        <!-- Attach file button -->
                        <Button DockPanel.Dock="Right" Click="FileUpload_Click"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Padding="6,0" Margin="4,0" ToolTip="Attach File">
                            <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Button>
                        <!-- Emoji button -->
                        <Button DockPanel.Dock="Right"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Padding="6,0" Click="EmojiButton_Click" ToolTip="Emoji">
                            <TextBlock Text="&#xE76E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Button>
                        <TextBox x:Name="MessageInput" Padding="8,6" FontSize="13"
                                 BorderBrush="{StaticResource BorderBrush}" VerticalAlignment="Center"
                                 KeyDown="MessageInput_KeyDown"
                                 AcceptsReturn="False" />
                    </DockPanel>
                    </Border>
                </Grid>
                </Border>
            </Grid>

            <!-- Video call overlay (WebView2) -->
            <Grid x:Name="VideoCallView" Visibility="Collapsed"
                  Background="#1a1a1a" Panel.ZIndex="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="12,8" Background="#252525"
                        BorderBrush="#333" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" x:Name="VideoCallLeaveBtn"
                                Click="VideoCallLeave_Click"
                                Background="#c4314b" Foreground="White" Padding="16,6"
                                BorderThickness="0" Cursor="Hand" FontSize="12" />
                        <TextBlock x:Name="VideoCallTitle" FontSize="14" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center" Margin="4,0,0,0" />
                    </DockPanel>
                </Border>
                <wv2:WebView2 x:Name="VideoWebView" Grid.Row="1" />
            </Grid>
        </Grid>

        <!-- Toast notification popup -->
        <Border x:Name="ToastBorder" Grid.Column="2"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="16,16" Padding="12,10" CornerRadius="8"
                Background="#323232" Visibility="Collapsed"
                MaxWidth="350">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Opacity="0.3" ShadowDepth="4" />
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="ToastTitle" FontSize="12" FontWeight="SemiBold"
                           Foreground="White" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ToastBody" FontSize="11" Foreground="#CCCCCC"
                           TextWrapping="Wrap" MaxHeight="40"
                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- Event Reminder Popup -->
        <Border x:Name="ReminderBorder" Grid.Column="2"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="16,16" Padding="16,14" CornerRadius="10"
                Background="White" Visibility="Collapsed"
                MaxWidth="340" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="3,0,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" Opacity="0.25" ShadowDepth="6" />
            </Border.Effect>
            <StackPanel>
                <emoji:TextBlock Text="&#x1F514;" FontSize="22" Margin="0,0,0,6" />
                <TextBlock x:Name="ReminderTitle" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ReminderTime" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,6" />
                <TextBlock x:Name="ReminderCountdown" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="ReminderJoinBtn" Style="{StaticResource PrimaryButton}"
                            Padding="14,6" Click="ReminderJoin_Click" Margin="0,0,8,0"
                            Visibility="Collapsed" />
                    <Button x:Name="ReminderDismissBtn" Padding="14,6"
                            Click="ReminderDismiss_Click"
                            Background="#E0E0E0" Foreground="#333333"
                            BorderThickness="0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Message context menu -->
        <Popup x:Name="MessageContextMenu" StaysOpen="False"
               Placement="MousePoint" AllowsTransparency="True">
            <Border Background="White" CornerRadius="6" Padding="4"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.15" ShadowDepth="2" />
                </Border.Effect>
                <StackPanel MinWidth="160">
                    <Button x:Name="CtxReply" Content="Reply" Click="CtxReply_Click"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="12,6" Cursor="Hand" />
                    <Button x:Name="CtxForward" Content="Forward" Click="CtxForward_Click"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="12,6" Cursor="Hand" />
                    <Button x:Name="CtxEdit" Content="Edit" Click="CtxEdit_Click"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="12,6" Cursor="Hand" />
                    <Button x:Name="CtxDelete" Content="Delete" Click="CtxDelete_Click"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="12,6" Cursor="Hand"
                            Foreground="Red" />
                    <Separator Margin="4,2" />
                    <StackPanel Orientation="Horizontal" Margin="8,4">
                        <Button Click="CtxReaction_Click" Tag="&#x1F44D;"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,2" Cursor="Hand">
                            <emoji:TextBlock Text="&#x1F44D;" FontSize="18" />
                        </Button>
                        <Button Click="CtxReaction_Click" Tag="&#x2764;&#xFE0F;"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,2" Cursor="Hand">
                            <emoji:TextBlock Text="&#x2764;" FontSize="18" />
                        </Button>
                        <Button Click="CtxReaction_Click" Tag="&#x1F602;"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,2" Cursor="Hand">
                            <emoji:TextBlock Text="&#x1F602;" FontSize="18" />
                        </Button>
                        <Button Click="CtxReaction_Click" Tag="&#x1F389;"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,2" Cursor="Hand">
                            <emoji:TextBlock Text="&#x1F389;" FontSize="18" />
                        </Button>
                        <Button Click="CtxReaction_Click" Tag="&#x1F44E;"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,2" Cursor="Hand">
                            <emoji:TextBlock Text="&#x1F44E;" FontSize="18" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Emoji picker popup -->
        <Popup x:Name="EmojiPicker" StaysOpen="False"
               Placement="Top" AllowsTransparency="True">
            <Border Background="White" CornerRadius="8" Padding="8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.15" ShadowDepth="2" />
                </Border.Effect>
                <WrapPanel MaxWidth="280">
                    <Button Click="EmojiPick_Click" Tag="&#x1F44D;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F44D;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F44E;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F44E;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x2764;&#xFE0F;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x2764;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F602;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F602;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F389;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F389;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F60A;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F60A;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F914;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F914;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F44F;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F44F;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F525;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F525;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x2705;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x2705;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x274C;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x274C;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F4AF;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F4AF;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F440;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F440;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F64F;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F64F;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x1F680;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x1F680;" FontSize="22" /></Button>
                    <Button Click="EmojiPick_Click" Tag="&#x2B50;"
                            Background="Transparent" BorderThickness="0" Padding="4" Cursor="Hand">
                        <emoji:TextBlock Text="&#x2B50;" FontSize="22" /></Button>
                </WrapPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
