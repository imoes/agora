<Window x:Class="AgoraWindows.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agora"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Border Background="White" CornerRadius="8" Margin="40"
                Padding="30" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.15" />
            </Border.Effect>

            <StackPanel>
                <!-- Logo / Title -->
                <Border Width="56" Height="56" CornerRadius="28"
                        Background="{StaticResource PrimaryBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="A" FontSize="26" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Agora" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,4" />
                <TextBlock Text="Collaboration Platform"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,24" />

                <!-- Server URL -->
                <TextBlock x:Name="ServerUrlLabel" Text="Server URL:" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox x:Name="ServerUrlBox" Text="https://localhost"
                         Padding="8" FontSize="13" Margin="0,0,0,12"
                         BorderBrush="{StaticResource BorderBrush}" />

                <!-- Username -->
                <TextBlock x:Name="UsernameLabel" Text="Username:" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox x:Name="UsernameBox" Padding="8" FontSize="13" Margin="0,0,0,12"
                         BorderBrush="{StaticResource BorderBrush}" />

                <!-- Password -->
                <TextBlock x:Name="PasswordLabel" Text="Password:" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <PasswordBox x:Name="PasswordBox" Padding="8" FontSize="13" Margin="0,0,0,20"
                             BorderBrush="{StaticResource BorderBrush}"
                             KeyDown="PasswordBox_KeyDown" />

                <!-- Remember credentials -->
                <CheckBox x:Name="RememberCheckBox" Content="Anmeldedaten speichern"
                          FontSize="12" Margin="0,0,0,16"
                          Foreground="{StaticResource TextSecondaryBrush}" />

                <!-- Error message -->
                <TextBlock x:Name="ErrorText" Text="" FontSize="12"
                           Foreground="Red" Margin="0,0,0,8"
                           TextWrapping="Wrap" Visibility="Collapsed" />

                <!-- Login button -->
                <Button x:Name="LoginButton" Content="Sign in"
                        Style="{StaticResource PrimaryButton}"
                        Click="LoginButton_Click"
                        HorizontalAlignment="Stretch" Height="38" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
